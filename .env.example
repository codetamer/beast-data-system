# =========================================================================
# BEAST QUANT DATA INGESTION SYSTEM - ENVIRONMENT CONFIGURATION TEMPLATE
# =========================================================================
# Rename this file to .env and fill in your details.

# Database URI Connection String
# Defaults to SQLite local database in the package 'data' folder
DB_URI=sqlite:///data/quant.db

# Polygon.io API Key
# Get a free/premium key at https://polygon.io/ for high-fidelity US market data
POLYGON_API_KEY=YOUR_POLYGON_API_KEY_HERE

# SEC EDGAR User-Agent
# The SEC requires a descriptive User-Agent header (Company Name & Contact Email)
# to identify your requests and prevent rate-limiting/blocks.
SEC_USER_AGENT=BeastQuant Research (your-email@example.com)

# System Settings
LOG_LEVEL=INFO
